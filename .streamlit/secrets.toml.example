# Copy this to .streamlit/secrets.toml for local development.
# On Streamlit Community Cloud, add these under Settings → Secrets.
# secrets.toml is gitignored — never commit real values.

FRED_API_KEY = "your_fred_api_key_here"
ANTHROPIC_API_KEY = "your_anthropic_api_key_here"
DATABRICKS_HOST = "https://your-workspace.azuredatabricks.net"
DATABRICKS_TOKEN = "your_personal_access_token"
DATABRICKS_JOB_ID = "12345"

# Cluster HTTP path — find it in Databricks → Compute → your cluster
# → Advanced Options → JDBC/ODBC tab
# Community Edition format: /sql/protocolv1/o/0/<cluster-id>
DATABRICKS_HTTP_PATH = "/sql/protocolv1/o/0/your-cluster-id"
