# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# Required for Bronze ingestion (FRED API — free registration at fred.stlouisfed.org)
FRED_API_KEY=your_fred_api_key_here
# Optional — enables LLM fallback in the SAS converter for complex patterns
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Required for scripts/run_pipeline.py
# Host: your workspace URL, e.g. https://adb-1234567890.12.azuredatabricks.net
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_personal_access_token
# HTTP path for the Analytics Dashboard page (reads Gold table live)
# Free Edition is serverless-only, so this comes from a SQL Warehouse, not a cluster:
# Databricks sidebar -> SQL Warehouses -> your warehouse -> Connection Details tab
# Format: /sql/1.0/warehouses/<warehouse-id>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
